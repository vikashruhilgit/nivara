# Copy to .env and adjust for your environment.
# Never commit .env to git.

# Application
ENVIRONMENT=development
DEBUG=true

# Database (Postgres on host port 5433 via docker-compose, or 5432 in-cluster)
DATABASE_URL=postgresql+asyncpg://investiq:investiq@localhost:5433/investiq

# Redis (host port 6380 via docker-compose, or 6379 in-cluster)
REDIS_URL=redis://localhost:6380/0

# Auth (bearer token model — TechSpec v1.3 direction).
# Access tokens are RS256 JWTs; keys are PEM files (generate via
# scripts/generate_keys.sh) or inline PEMs (useful for CI/tests).
JWT_ALGORITHM=RS256
JWT_KID=dev
JWT_ISSUER=investiq
JWT_AUDIENCE=investiq-mobile
JWT_PRIVATE_KEY_PATH=./secrets/jwt_private.pem
JWT_PUBLIC_KEY_PATH=./secrets/jwt_public.pem
ACCESS_TOKEN_EXPIRES_MINUTES=15
REFRESH_TOKEN_EXPIRES_DAYS=30

# Argon2 password hashing — tune per environment.
ARGON2_TIME_COST=2
ARGON2_MEMORY_COST=65536
ARGON2_PARALLELISM=2

# Broker token encryption (AES-256-GCM per-user HKDF).
# Comma-separated list of URL-safe base64 32-byte master keys; primary first,
# older keys afterwards for decrypt-only fallback during rotation.
# Generate: python -c "import os, base64; print(base64.urlsafe_b64encode(os.urandom(32)).decode())"
MASTER_ENCRYPTION_KEY=

# Broker integrations (placeholders — fill per environment)
# Per-user Alpaca access uses per-user API keys entered in-app
# (POST /api/auth/broker/alpaca/credentials), stored encrypted per user.
# ALPACA_API_KEY/ALPACA_API_SECRET are optional dev/single-account convenience
# only and are NOT required for the per-user flow. ALPACA_OAUTH_* are reserved
# for a future OAuth follow-up and are currently unused.
ALPACA_API_KEY=
ALPACA_API_SECRET=
ALPACA_BASE_URL=https://paper-api.alpaca.markets
ALPACA_OAUTH_CLIENT_ID=
ALPACA_OAUTH_REDIRECT_URI=http://localhost:8000/api/auth/broker/alpaca/callback

ZERODHA_API_KEY=
ZERODHA_API_SECRET=

# Push notifications
EXPO_ACCESS_TOKEN=

# --- MODE E: Risk Guardian & Notifications (M3-20) --------------------------
# FRED API key (also used by FX pipeline above; kept here for clarity).
FRED_API_KEY=
# Expo push-service access token (authenticated Push API).
EXPO_PUSH_ACCESS_TOKEN=

# --- Transactional email (SMTP) ---------------------------------------------
# App-wide SMTP transport for transactional mail (e.g. password reset).
# All optional: when SMTP_HOST / SMTP_FROM_EMAIL are empty the sender degrades
# gracefully (no email; in development the reset code is logged for testing).
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM_EMAIL=
SMTP_USE_TLS=true

# --- Password reset (forgot-password flow) ----------------------------------
PASSWORD_RESET_TOKEN_EXPIRES_MINUTES=30
PASSWORD_RESET_RATE_LIMIT_MAX=5
PASSWORD_RESET_RATE_LIMIT_WINDOW_SECONDS=900
# Base URL used to build the reset link in the email body.
APP_PUBLIC_BASE_URL=http://localhost:8000

# --- MODE 4: AI-Enhanced Analysis (M3-17) -----------------------------------
# OFF by default. Shadow mode logs AI output without blending into composite.
# Flip AI_ANALYSIS_SHADOW_MODE=false ONLY when legal review flag is also set.
AI_ANALYSIS_ENABLED=false
AI_ANALYSIS_SHADOW_MODE=true
AI_ANALYSIS_WEIGHT=0.20
AI_ANALYSIS_LEGAL_REVIEW_APPROVED=false
AI_ANALYSIS_PROVIDER=claude_cli
AI_ANALYSIS_TIMEOUT_S=30.0
# ANTHROPIC_API_KEY=
