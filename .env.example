# Copy to .env and adjust for your environment.
# Never commit .env to git.

# Application
ENVIRONMENT=development
DEBUG=true

# Database (Postgres on host port 5433 via docker-compose, or 5432 in-cluster)
DATABASE_URL=postgresql+asyncpg://investiq:investiq@localhost:5433/investiq

# Redis (host port 6380 via docker-compose, or 6379 in-cluster)
REDIS_URL=redis://localhost:6380/0

# Auth (bearer token model — TechSpec v1.3 direction)
JWT_SECRET=please-change-me
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRES_MINUTES=15
REFRESH_TOKEN_EXPIRES_DAYS=30

# Broker integrations (placeholders — fill per environment)
ALPACA_API_KEY=
ALPACA_API_SECRET=
ALPACA_BASE_URL=https://paper-api.alpaca.markets

ZERODHA_API_KEY=
ZERODHA_API_SECRET=

# Push notifications
EXPO_ACCESS_TOKEN=
